@model AISIots.ViewModels.SettingsModel

<h2>Настройки</h2>

<p>Пользователь: <strong>@Model.CurrentUserLogin</strong> (@Model.CurrentUserRole)</p>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<hr/>

<h4>Смена пароля</h4>
<form asp-action="ChangePassword" method="post">
    <div class="row g-2">
        <div class="col-md-4">
            <input type="password" name="oldPassword" class="form-control" placeholder="Текущий пароль" required/>
        </div>
        <div class="col-md-4">
            <input type="password" name="newPassword" class="form-control" placeholder="Новый пароль" required
                   minlength="6"/>
        </div>
        <div class="col-md-4">
            <input type="password" name="confirmPassword" class="form-control" placeholder="Повторите пароль" required/>
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100">Изменить пароль</button>
        </div>
    </div>
</form>

<hr/>

<h4>История действий</h4>
<table class="table table-striped">
    <thead>
    <tr>
        <th>Время</th>
        <th>Пользователь</th>
        <th>Действие</th>
        <th>Объект</th>
        <th>Название</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var log in Model.LogsPage)
    {
        <tr>
            <td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm")</td>
            <td>@log.UserLogin</td>
            <td>@log.Action</td>
            <td>@log.EntityType</td>
            <td>@log.TargetName</td>
        </tr>
    }
    </tbody>
</table>

@if (Model.LogsPage.Count == 0)
{
    <p class="text-muted">История действий пуста.</p>
}

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Settings", new { page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@if (Model.IsAdmin)
{
    <hr/>

    <h4>Управление пользователями</h4>
    <table class="table table-bordered">
        <thead>
        <tr>
            <th>Логин</th>
            <th>Роль</th>
            <th>Изменить пароль</th>
            <th>Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.Login</td>
                <td>@user.RoleName</td>
                <td>
                    @if (user.RoleIdEditable)
                    {
                        <form asp-action="ChangeUserPassword" asp-controller="User" method="post"
                              style="display:inline">
                            <input type="hidden" name="login" value="@user.Login"/>
                            <input type="password" name="newPassword" class="form-control form-control-sm"
                                   style="width:160px;display:inline" placeholder="Новый пароль" required
                                   minlength="6"/>
                            <button type="submit" class="btn btn-sm btn-warning">Сменить</button>
                        </form>
                    }
                </td>
                <td>
                    @if (user.RoleIdEditable)
                    {
                        <form asp-action="ChangeUserRole" asp-controller="User" method="post" style="display:inline">
                            <input type="hidden" name="login" value="@user.Login"/>
                            <select name="newRoleId" class="form-select form-select-sm"
                                    style="width:auto;display:inline">
                                <option value="2" selected="@(user.RoleId == 2)">Admin</option>
                                <option value="3" selected="@(user.RoleId == 3)">User</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-secondary">Сменить роль</button>
                        </form>
                        <form asp-action="DeleteUser" asp-controller="User" method="post" style="display:inline">
                            <input type="hidden" name="login" value="@user.Login"/>
                            <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('Удалить пользователя @user.Login?')">Удалить
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">Нельзя изменять</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>

    <hr/>

    <h5>Создать нового пользователя</h5>
    <form asp-action="CreateUser" asp-controller="User" method="post">
        <div class="row g-2">
            <div class="col-md-3">
                <input type="text" name="login" class="form-control" placeholder="Логин" required/>
            </div>
            <div class="col-md-3">
                <input type="password" name="password" class="form-control" placeholder="Пароль" required
                       minlength="6"/>
            </div>
            <div class="col-md-3">
                <input type="password" name="confirmPassword" class="form-control" placeholder="Повторите пароль"
                       required/>
            </div>
            <div class="col-md-2">
                <select name="roleId" class="form-select">
                    <option value="2">Admin</option>
                    <option value="3" selected>User</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-success w-100">Создать</button>
            </div>
        </div>
    </form>
}